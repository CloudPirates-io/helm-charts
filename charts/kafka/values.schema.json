                        "namespace": {
                            "type": "string"
                        },
                        "namespaceSelector": {
                            "type": "object"
                        },
                        "relabelings": {
                            "type": "array"
                        },
                        "scrapeTimeout": {
                            "type": "string"
                        },
                        "selector": {
                            "type": "object"
                        }
                    }
                }
            }
